  <Kpis>
    <Kpi dwd:design-time-name="7a8df621-3f3f-440d-865b-3fd3c5702281">
      <ID>KPI</ID>
      <Name>NUMBER_OF_DONATIONS</Name>
      <AssociatedMeasureGroupID>Donation</AssociatedMeasureGroupID>
      <Value>[Measures].[Donation Count]</Value>
      <Goal>505</Goal>
      <Status>IIf (KPIVALUE( "NUMBER_OF_DONATIONS" ) &gt; KPIGoal("NUMBER_OF_DONATIONS"), 1, -1)
</Status>
      <Trend>IIF(
  [Date].[Hierarchy].CurrentMember.Level IS [Date].[Hierarchy].[Month],
  -- CASE: Month 
  IIF(
    IsEmpty(
      ([Measures].[Donation Count], [Date].[Hierarchy].CurrentMember.PrevMember)
    ),
    NULL,
    ([Measures].[Donation Count], [Date].[Hierarchy].CurrentMember)
    -
    ([Measures].[Donation Count], [Date].[Hierarchy].CurrentMember.PrevMember)
  ),
  -- CASE: Only Year 
  IIF(
    IsEmpty(
      ([Measures].[Donation Count], [Date].[Hierarchy].CurrentMember.PrevMember)
    ),
    NULL,
    ([Measures].[Donation Count], [Date].[Hierarchy].CurrentMember)
    -
    ([Measures].[Donation Count], [Date].[Hierarchy].CurrentMember.PrevMember)
  )
)</Trend>
      <TrendGraphic>Smiley Face</TrendGraphic>
      <StatusGraphic>Variance Arrow</StatusGraphic>
    </Kpi>
    <Kpi dwd:design-time-name="728ccb5f-69bc-4c71-88f8-908e33a8b26c">
      <ID>KPI 1</ID>
      <Name>NUMBER_OF_PATRONS</Name>
      <AssociatedMeasureGroupID>Patron Date Joined</AssociatedMeasureGroupID>
      <Value>[Measures].[Patron Date Joined Count]</Value>
      <Goal>100</Goal>
      <Status>IIf (KPIVALUE( "NUMBER_OF_PATRONS" ) &gt; KPIGoal("NUMBER_OF_PATRONS"), 1, -1)
</Status>
      <Trend>IIF(
  [Date].[Hierarchy].CurrentMember.Level IS [Date].[Hierarchy].[Month],
  -- CASE: Month 
  IIF(
    IsEmpty(
      ([Measures].[Patron Date Joined Count], [Date].[Hierarchy].CurrentMember.PrevMember)
    ),
    NULL,
    ([Measures].[Patron Date Joined Count], [Date].[Hierarchy].CurrentMember)
    -
    ([Measures].[Patron Date Joined Count], [Date].[Hierarchy].CurrentMember.PrevMember)
  ),
  -- CASE: Only Year 
  IIF(
    IsEmpty(
      ([Measures].[Patron Date Joined Count], [Date].[Hierarchy].CurrentMember.PrevMember)
    ),
    NULL,
    ([Measures].[Patron Date Joined Count], [Date].[Hierarchy].CurrentMember)
    -
    ([Measures].[Patron Date Joined Count], [Date].[Hierarchy].CurrentMember.PrevMember)
  )
)</Trend>
      <TrendGraphic>Standard Arrow</TrendGraphic>
      <StatusGraphic>Variance Arrow</StatusGraphic>
    </Kpi>
  </Kpis>
</Cube>